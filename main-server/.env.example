APP_ENV=dev
NODE_ENV=development

MAIN_SERVER_PORT=4000

# dev / local password mode
DB_AUTH_MODE=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=AMFPI
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_SSL_MODE=disable

# staging / production Entra mode
#
# If Key Vault access is not assigned, set DB_HOST/DB_PORT/DB_NAME/DB_USER
# directly as Function App settings. These values are not passwords.
#
# If Key Vault access is assigned later, set AZURE_KEY_VAULT_URL and the
# KV_SECRET_* names below instead.
AZURE_KEY_VAULT_URL=
AZURE_POSTGRES_SCOPE=https://ossrdbms-aad.database.windows.net/.default
KV_SECRET_DB_HOST=your-db-host-secret-name
KV_SECRET_DB_PORT=your-db-port-secret-name
KV_SECRET_DB_NAME=your-db-name-secret-name
KV_SECRET_DB_USER=your-db-user-secret-name

DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000

LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:3000

# Setup workbook source retention. Use Azurite/connection string locally and
# managed identity with the account URL in Azure.
SETUP_IMPORT_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
SETUP_IMPORT_STORAGE_ACCOUNT_URL=
SETUP_IMPORT_STORAGE_CONTAINER=process-setup-imports

SEED_ENABLED=true
SEED_MODE=dev
SEED_RESET_DATABASE=true
