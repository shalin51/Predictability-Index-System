{
  "name": "@amfpi/dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "verify:env:dev": "node scripts/verify-env.cjs .env.development",
    "verify:env:staging": "node scripts/verify-env.cjs .env.staging",
    "verify:env:production": "node scripts/verify-env.cjs .env.production",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.9.1",
    "react": "^18.3.1",
    "react-redux": "^9.2.0",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.3.3",
    "vite": "^6.4.3"
  }
}
